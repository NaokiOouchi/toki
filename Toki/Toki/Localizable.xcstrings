{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ left" : {
      "comment" : "Central remaining text during an event. e.g. '30 min left'.",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "%@ left" }
        },
        "ja" : {
          "stringUnit" : { "state" : "translated", "value" : "残り %@" }
        }
      }
    },
    "%@ until next" : {
      "comment" : "Central subtitle when there's a next event soon. e.g. '15 min until next'.",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "%@ until next" }
        },
        "ja" : {
          "stringUnit" : { "state" : "translated", "value" : "次まで %@" }
        }
      }
    },
    "%1$lld hr %2$lld min" : {
      "comment" : "Duration: hours + minutes. e.g. '1 hr 30 min'.",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "%1$lld hr %2$lld min" }
        },
        "ja" : {
          "stringUnit" : { "state" : "translated", "value" : "%1$lld 時間 %2$lld 分" }
        }
      }
    },
